generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


model departments {
  id         String     @id @default(uuid())
  name       String     @unique
  head_id    String?
  created_at DateTime   @default(now())
  profiles   profiles[]
}

model profiles {
  id                  String             @id @default(uuid())
  full_name           String
  email               String             @unique
  password            String?             
  phone               String?
  role                String             @default("employee")
  department_id       String?
  department          departments?       @relation(fields: [department_id], references: [id])
  managers            profiles[]         @relation("EmployeeManagers")
  subordinates        profiles[]         @relation("EmployeeManagers")
  designation         String?
  employee_code       String?            @unique
  date_of_joining     DateTime?
  total_leaves        Int                @default(0)
  available_leaves    Float              @default(0)
  comp_off_leaves     Float              @default(0)
  is_active           Boolean            @default(false)
  is_deleted          Boolean            @default(false)
  email_verified      Boolean            @default(false)
  otp_code            String?
  otp_expires_at      DateTime?
  reset_token         String?
  reset_token_expires_at DateTime?
  verification_status String             @default("pending")
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  leave_requests      leave_requests[]   @relation("EmployeeLeaves")
  approved_leaves     leave_requests[]   @relation("ApprovedLeaves")
  comp_off_grants     CompOffGrant[]
}

model leave_requests {
  id                      String    @id @default(uuid())
  employee_id             String
  employee                profiles  @relation("EmployeeLeaves", fields: [employee_id], references: [id])
  leave_type              String
  start_date              DateTime
  end_date                DateTime
  total_days              Float
  paid_days               Float?
  reason                  String    @db.Text
  status                  String    @default("pending")
  approved_by             String?
  approver                profiles? @relation("ApprovedLeaves", fields: [approved_by], references: [id])
  admin_note              String?   @db.Text
  
  // Realistic Timings
  approved_at             DateTime?
  rejected_at             DateTime?
  withdrawal_requested_at DateTime?
  withdrawn_at            DateTime?
  withdrawn_dates         Json?     // Array of date strings that are withdrawn

  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
}

model holidays {
  id          String   @id @default(uuid())
  name        String
  date        DateTime @unique
  description String?  @db.Text
  type        String   @default("public")
  created_at  DateTime @default(now())
}

model audit_logs {
  id           String   @id @default(uuid())
  actor_id     String?
  action       String
  target_table String
  target_id    String
  created_at   DateTime @default(now())
}

model CompOffGrant {
  id           String   @id @default(uuid())
  employeeId   String
  employee     profiles @relation(fields: [employeeId], references: [id])
  daysGranted  Float
  reason       String
  grantedBy    String?
  grantedAt    DateTime @default(now())
  workedDates  Json?
  status       String   @default("approved") // "pending", "approved", "rejected"
  adminNote    String?  @db.Text
}
